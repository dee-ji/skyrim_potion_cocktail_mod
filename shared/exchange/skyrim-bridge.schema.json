{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skyrim-potion-cocktails.local/schemas/skyrim-bridge.schema.json",
  "title": "Skyrim Potion Cocktails Bridge Export",
  "type": "object",
  "required": ["schema_version", "character"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "exported_at": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "character": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "quantity"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "quantity": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "known_effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ingredient", "effects"],
        "additionalProperties": false,
        "properties": {
          "ingredient": {
            "type": "string",
            "minLength": 1
          },
          "effects": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
